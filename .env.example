# Server configuration
PORT=3000
NODE_ENV=production

# Database configuration (Prisma SQLite connection string)
DATABASE_URL="file:./users.db"

# Third-party Visual Crossing weather API key
WEATHER_API_KEY="your_visual_crossing_api_key_here"

# Authentication settings (replace with cryptographically secure key)
JWT_SECRET="your_jwt_secret_here"
JWT_EXPIRY="24h"

# Stripe payment processing (get keys from https://dashboard.stripe.com/test/apikeys)
# Leave empty to keep upgrade free during development
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Webhook secret from Stripe CLI or dashboard (optional in dev, required in production)
STRIPE_WEBHOOK_SECRET="whsec_..."
